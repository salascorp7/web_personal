# Copia este archivo como .env y rellena los valores

# Google OAuth Client ID (público — el mismo en frontend y backend)
VITE_GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxx.apps.googleusercontent.com

# JWT para sesiones propias (clave larga y aleatoria, mínimo 32 chars)
JWT_SECRET=una_clave_larga_aleatoria_minimo_32_chars

# Tu email de Google — será el único con acceso admin
USUARIOS_ADMIN=tucorreo@gmail.com
